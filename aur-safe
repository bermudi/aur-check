  printf -v _new_expansion_dep_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\ndepends=(\n  "$(printf alsa-lib)"\n)\nsource=("https://example.com/pkg-1.tar")\nsha256sums=(%s)' "$_sum1"
  printf -v _old_stray_dep_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nmakedepends=()\nsource=(\"https://example.com/pkg-1.tar\")\nsha256sums=(%s)" "$_sum1"
  printf -v _new_stray_dep_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nmakedepends=()\n  'alsa-lib'\nsource=(\"https://example.com/pkg-1.tar\")\nsha256sums=(%s)" "$_sum1"
