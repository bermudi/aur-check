  _colon_out=$(classify_diff_rules "cls-colon-text" "$_CLASS_DIR" "$_CLASS_BASE" 2>&1 >/dev/null)
  if printf '%s\n' "$_colon_out" | grep -q 'package build instructions changed'; then
    log "  $(c_green "PASS") classifier-detail-build-logic-colon-in-text"; pass=$((pass+1))
  else
    log "  $(c_red "FAIL") classifier-detail-build-logic-colon-in-text (got: $_colon_out)"
    fail=$((fail+1))
  fi

  classify_diff_rules bad-ref "$_edge_dir" "0000000000000000000000000000000000000000" >/dev/null 2>&1
  local _bad_class="$SCAN_DIFF_CLASS" _bad_rc
  _LLM_TEST_CALLS=0
  scan_diff_rules bad-ref "$_edge_dir" "0000000000000000000000000000000000000000" >/dev/null 2>&1
  _bad_rc=$?
  if [ "$_bad_class" = audit_unavailable ] && [ "$_bad_rc" -eq 1 ] && [ "$_LLM_TEST_CALLS" -eq 0 ]; then
    log "  $(c_green "PASS") classifier-audit-unavailable-no-llm"; pass=$((pass+1))
  else
    log "  $(c_red "FAIL") classifier-audit-unavailable-no-llm"
    fail=$((fail+1))
  fi

  # shellcheck disable=SC2329  # test seam, called indirectly by llm_check_boring_edge
  _llm_boring_backend() {
    local n=0
    if [[ -r "$_LLM_TEST_COUNT_FILE" ]]; then
      read -r n <"$_LLM_TEST_COUNT_FILE"
    fi
    printf '%s\n' "$((n + 1))" >"$_LLM_TEST_COUNT_FILE"
    case "$_LLM_TEST_MODE" in
      ok) printf 'VERDICT: BORING_EDGE_OK\nREASON: test seam\n' ;;
      needs) printf 'VERDICT: NEEDS_HUMAN\n' ;;
      malformed) printf 'BORING\n' ;;
      fail) return 1 ;;
      missing) return 127 ;;
    esac
  }

  tl() { # tl name enabled mode expect-rc expect-calls
    local name="$1" enabled="$2" mode="$3" expect_rc="$4" expect_calls="$5" got_rc got_calls
    LLM_AUTO_BORING="$enabled"; _LLM_TEST_MODE="$mode"; _LLM_TEST_COUNT_FILE="$_cls_state/llm-count"
    printf '0\n' >"$_LLM_TEST_COUNT_FILE"
    scan_diff_rules "$_edge_pkg" "$_edge_dir" "$_edge_base" >/dev/null 2>&1
    got_rc=$?
    read -r got_calls <"$_LLM_TEST_COUNT_FILE"
    if [ "$got_rc" -eq "$expect_rc" ] && [ "$got_calls" -eq "$expect_calls" ]; then
      log "  $(c_green "PASS") llm-$name"; pass=$((pass+1))
    else
      log "  $(c_red "FAIL") llm-$name (expected rc $expect_rc/calls $expect_calls, got rc $got_rc/calls $got_calls)"
      fail=$((fail+1))
    fi
  }
  tl disabled-not-invoked 0 ok 2 0
  tl exact-ok-auto-passes 1 ok 0 1
  tl needs-human-reviews 1 needs 2 1
  tl malformed-reviews 1 malformed 2 1
  tl command-failure-reviews 1 fail 2 1
  tl missing-pi-reviews 1 missing 2 1

  printf '%s\t%s\t%s\n' "$_edge_base" "1970-01-01T00:00:00Z" "file://$_edge_dir" >"$ACCEPTED_DIR/$_edge_pkg"
  _AUR_TEST_DIR="$_edge_dir"; AUR_SAFE_STAGING=1
  LLM_AUTO_BORING=1; _LLM_TEST_MODE=ok; _LLM_TEST_CALLS=0
  ta "llm-auto-green-check-stages-tip" 0 check_pkg "$_edge_pkg"
  if [ -f "$STAGED_DIR/$_edge_pkg" ] && [ "$(awk -F '\t' '{print $1}' "$STAGED_DIR/$_edge_pkg")" = "$_edge_tip" ]; then
    log "  $(c_green "PASS") llm-auto-green-staged-sha"; pass=$((pass+1))
  else log "  $(c_red "FAIL") llm-auto-green-staged-sha"; fail=$((fail+1)); fi
  AUR_SAFE_STAGING=""; _AUR_TEST_DIR=""

  unset -f _class_bld tc_class tl _llm_boring_backend
  LLM_AUTO_BORING="$_cls_old_llm"
  STATE_DIR="$_cls_sd"; ACCEPTED_DIR="$_cls_ad"; STAGED_DIR="$_cls_st"; MANIFEST_FILE="$_cls_mf"
  rm -rf "$_clx" "$_cls_state"

  _AUR_TEST_Q=""
  unset -f _bl_bld

  AUR_SAFE_STAGING=""
  AUR_URL="$_osr"; STATE_DIR="$_osd2"; STAGED_DIR="$_ost2"; MANIFEST_FILE="$_omf2"
  rm -rf "$_fbx" "$_fsd"

  # --- exact pre-makepkg SHA guard (Finding S) -----------------------------
  log ""
  log "  $(c_dim "-- makepkg exact-SHA guard --")"
  local _mg_root _mg_repo _mg_state _mg_sha _mg_marker
  local _mg_sd="$STATE_DIR" _mg_ad="$ACCEPTED_DIR" _mg_st="$STAGED_DIR" _mg_mf="$MANIFEST_FILE"
  _mg_root=$(mktemp -d); _mg_repo="$_mg_root/guard-pkg"; _mg_state="$_mg_root/state"
  mkdir -p "$_mg_repo" "$_mg_state/accepted" "$_mg_state/staged"
  ( cd "$_mg_repo" || exit 1
    git -c init.defaultBranch=master init -q
    git config user.email t@t; git config user.name t
    printf 'pkgname=guard-pkg\npkgver=1\npkgrel=1\n' >PKGBUILD
    printf 'pkgbase = guard-pkg\n\tpkgver = 1\n\tpkgrel = 1\n\npkgname = guard-pkg\n' >.SRCINFO
    git add -A; git commit -qm base )
  _mg_sha=$(git -C "$_mg_repo" rev-parse HEAD); _mg_marker="$_mg_root/makepkg-called"
  STATE_DIR="$_mg_state"; ACCEPTED_DIR="$_mg_state/accepted"; STAGED_DIR="$_mg_state/staged"; MANIFEST_FILE="$_mg_state/last-gate"
  _atomic_write_record "$STAGED_DIR/guard-pkg" "$_mg_sha"$'\t'"1970-01-01T00:00:00Z"$'\t'"file://$_mg_repo"
  printf 'guard-pkg\n' >"$MANIFEST_FILE"
  # shellcheck disable=SC2329  # test seam, invoked indirectly by cmd_makepkg
  _exec_real_makepkg() { printf '%s\n' "$*" >"$_mg_marker"; return 0; }
  # shellcheck disable=SC2329  # test helpers, invoked through ta
  _mg_run() { ( cd "$_mg_repo" && AUR_SAFE_AS_MAKEPKG=1 AUR_SAFE_TRANSACTION_ACTIVE=1 cmd_makepkg "$@" ); }
  # shellcheck disable=SC2329
  _mg_no_tx() { ( cd "$_mg_repo" && AUR_SAFE_AS_MAKEPKG=1 AUR_SAFE_TRANSACTION_ACTIVE=0 cmd_makepkg "$@" ); }
  ta "makepkg-guard-no-transaction-blocks" 1 _mg_no_tx
  ta "makepkg-guard-repackage-blocks" 1 _mg_run --repackage
  ta "makepkg-guard-context-switch-blocks" 1 _mg_run --dir /tmp
  ta "makepkg-guard-matching-sha-runs" 0 _mg_run --syncdeps --noconfirm
  if grep -q -- '--cleanbuild --force --syncdeps --noconfirm' "$_mg_marker" 2>/dev/null; then
    log "  $(c_green "PASS") makepkg-guard-forces-fresh-artifact-and-preserves-args"; pass=$((pass+1))
  else log "  $(c_red "FAIL") makepkg-guard-forces-fresh-artifact-and-preserves-args"; fail=$((fail+1)); fi

  printf '# changed\n' >>"$_mg_repo/PKGBUILD"
  ta "makepkg-guard-dirty-tracked-blocks" 1 _mg_run
  git -C "$_mg_repo" checkout -q -- PKGBUILD
  printf 'payload\n' >"$_mg_repo/evil.install"
  ta "makepkg-guard-untracked-script-blocks" 1 _mg_run
  rm -f "$_mg_repo/evil.install"
  : >"$MANIFEST_FILE"
  ta "makepkg-guard-unstaged-dependency-blocks" 1 _mg_run
  printf 'guard-pkg\n' >"$MANIFEST_FILE"
  printf 'pkgname=guard-pkg\npkgver=2\npkgrel=1\n' >"$_mg_repo/PKGBUILD"
  git -C "$_mg_repo" add PKGBUILD; git -C "$_mg_repo" commit -qm newer
  ta "makepkg-guard-window-commit-blocks" 1 _mg_run

  unset -f _mg_run _mg_no_tx
  STATE_DIR="$_mg_sd"; ACCEPTED_DIR="$_mg_ad"; STAGED_DIR="$_mg_st"; MANIFEST_FILE="$_mg_mf"
  rm -rf "$_mg_root"

  log ""
  log "  $(c_bold "$pass passed, $fail failed")"
  exit $fail
}

usage() {
  cat <<EOF
aur-safe — deterministic gate for AUR updates

usage:
  aur-safe gate                gate all pending AUR updates
  aur-safe check <pkg> ...     gate specific cached package(s)
  aur-safe audit <pkg>         advisory scan of an uncached/new package
  aur-safe scan                scan installed pkgs for payload patterns
  aur-safe explain [pkg]       LLM second-opinion on last flagged diff
  aur-safe accept              promote staged refs (called by the wrapper)
  aur-safe rules               list active rules
  aur-safe wrapper             print the suggested shell wrapper (not installed)
  aur-safe selftest            run built-in rule tests

env:
  AUR_SAFE_YAY_CACHE          yay cache dir     (default: ~/.cache/yay)
  AUR_SAFE_PARU_CACHE         paru cache dir    (default: ~/.cache/paru/clone)
  AUR_SAFE_STATE_DIR          state dir         (default: ~/.cache/aur-safe)
  AUR_SAFE_MODEL              explain model     (default: zai/glm-5.2)
  AUR_SAFE_EXPLAIN_MAXLINES   diff truncation   (default: 1000)
  AUR_SAFE_BRANCH             remote branch     (default: master)
  AUR_SAFE_AUR_URL            AUR base URL      (default: https://aur.archlinux.org)
  AUR_SAFE_CONFIG             config file       (default: ~/.config/aur-safe/config)
  AUR_SAFE_LLM_AUTO_BORING    1 enables strict LLM verifier for boring-edge diffs
EOF
}

###############################################################################
# dispatch
###############################################################################
if [[ "${AUR_SAFE_AS_MAKEPKG:-}" == 1 ]]; then
  cmd_makepkg "$@"
  exit $?
fi
[[ $# -eq 0 ]] && { usage; exit 3; }
case "$1" in
  gate)     shift; cmd_gate "$@" ;;
  check)    shift; cmd_check "$@" ;;
  audit)    shift; cmd_audit "$@" ;;
  scan)     shift; cmd_scan "$@" ;;
  explain)  shift; cmd_explain "$@" ;;
  accept)   shift; cmd_accept "$@" ;;
  rules)    shift; cmd_rules "$@" ;;
  wrapper)  shift; cmd_wrapper "$@" ;;
  selftest) shift; cmd_selftest "$@" ;;
  -h|--help|help) usage ;;
  *) die "unknown command '$1' (try: aur-safe --help)" ;;
esac
