    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tdepends = alsa-lib\n\tdepends = ttf-font\n\tmakedepends = cmake\n\tcheckdepends = alsa-lib>=1.2'

  tc_class srcinfo-unknown-dep-review review 2 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tdepends = suspicious-aur-dep'

  # noextract= is .SRCINFO metadata (a versioned *filename*, runs no code) —
  # an added/changed line must not force review. Append to an otherwise
  # unchanged .SRCINFO so the only diff is the noextract line.
  tc_class srcinfo-noextract-boring boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tnoextract = foo-1.0.deb'

  # Real cursor-bin shape: version bump renames the noextract= filename AND the
  # source= URL (same host) AND the sha512sum. noextract + source + checksum
  # must all clear as boring.
  printf -v _noextract_old_pkgbuild 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsource=("https://example.com/foo-1.0.deb")\nsha256sums=(%s)' "$_sum1"
  printf -v _noextract_new_pkgbuild 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\nsource=("https://example.com/foo-2.0.deb")\nsha256sums=(%s)' "$_sum1"
  _noextract_old_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tnoextract = foo-1.0.deb\n\tsource = https://example.com/foo-1.0.deb\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _noextract_new_src=$'pkgbase = cls-pkg\n\tpkgver = 2.0\n\tpkgrel = 1\n\tnoextract = foo-2.0.deb\n\tsource = https://example.com/foo-2.0.deb\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'

  tc_class srcinfo-noextract-version-rename boring 0 \
    "$_noextract_old_pkgbuild" \
    "$_noextract_new_pkgbuild" \
    "$_noextract_old_src" \
    "$_noextract_new_src"

  # Intra-pkgbase dep: cls-split-tools depends on cls-split (the pkgbase, also a
  # member), version-pinned to pkgver. Neither is in the test pacman sync db, so
  # only the intra-pkgbase branch can clear it. The nvidia-580xx-utils shape.
  tc_class srcinfo-intra-pkgbase-dep-base boring 0 \
    "$_split_old_pkgbuild" \
    "$_split_new_pkgbuild" \
    "$_split_base_old_src" \
    "$_split_base_new_src"

  # Intra-pkgbase dep on a SIBLING member (not the pkgbase name): cls-split
  # depends on cls-split-tools. Proves the pkgname= member branch, not just
  # pkgbase-name equality.
  tc_class srcinfo-intra-pkgbase-dep-member boring 0 \
    "$_split_old_pkgbuild" \
    "$_split_new_pkgbuild" \
    "$_split_member_old_src" \
    "$_split_member_new_src"

  tc_class srcinfo-leading-ws-only boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_space_src" \
    "$_new_tab_src"

  tc_class srcinfo-section-move-review review 2 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src_move_src" \
    "$_new_src_move_src"

  tc_class validpgpkeys-hex-review review 2 \
    "$_old_vpgp_pkg" \
    "$_new_vpgp_pkg" \
    "$_old_vpgp_src" \
    "$_new_vpgp_src"

  # Regression: a checksum element changed DEEP in a multi-element array, where
  # git splits the diff into separate hunks and emits the sha256sums=( opener
  # ONLY in the @@ header label (not the hunk body). Before the fix,
  # _pkgbuild_checksum_array_line reset in_cs on every @@ and never re-entered
  # the array → the changed hex fell through to review (the nvidia-580xx-utils
  # false positive). The gap between pkgver and the changed sum forces the
  # 2-hunk split on git's default config.
  _deep_pad=""
  for _ in $(seq 1 12); do _deep_pad+=$'# padding to force a 2-hunk split\n'; done
  printf -v _deep_cs_old_pkg 'pkgbase=cls-pkg\npkgver=1.0\n%ssource=("https://example.com/pkg.tar")\nsha256sums=(\n  %s\n  %s\n  %s\n  %s\n)' \
    "$_deep_pad" "$_sum1" "$_sum1" "$_sum1" "$_sum1"
  printf -v _deep_cs_new_pkg 'pkgbase=cls-pkg\npkgver=2.0\n%ssource=("https://example.com/pkg.tar")\nsha256sums=(\n  %s\n  %s\n  %s\n  %s\n)' \
    "$_deep_pad" "$_sum1" "$_sum1" "$_sum1" "$_sum2"
  _deep_cs_old_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/pkg.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _deep_cs_new_src=$'pkgbase = cls-pkg\n\tpkgver = 2.0\n\tpkgrel = 1\n\tsource = https://example.com/pkg.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  tc_class pkgbuild-checksum-deep-in-array-boring boring 0 \
    "$_deep_cs_old_pkg" \
    "$_deep_cs_new_pkg" \
    "$_deep_cs_old_src" \
    "$_deep_cs_new_src"

  # Same latent bug for optdepends: a deep entry change where git puts
  # optdepends=( only in the @@ header label. pkgver also changes (above the
  # padding) so git emits two hunks and the optdepends=( opener lands in the
  # 2nd hunk's @@ label, not the body.
  printf -v _deep_opt_old_pkg 'pkgbase=cls-pkg\npkgver=1.0\n%soptdepends=(\n  %s\n  %s\n  %s\n  %s\n)' \
    "$_deep_pad" "'dep1: one'" "'dep2: two'" "'dep3: three'" "'dep4: four'"
  printf -v _deep_opt_new_pkg 'pkgbase=cls-pkg\npkgver=2.0\n%soptdepends=(\n  %s\n  %s\n  %s\n  %s\n)' \
    "$_deep_pad" "'dep1: one'" "'dep2: two'" "'dep3: three'" "'dep4: RENAMED'"
  _deep_opt_old_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\npkgname = cls-pkg'
  _deep_opt_new_src=$'pkgbase = cls-pkg\n\tpkgver = 2.0\n\tpkgrel = 1\n\npkgname = cls-pkg'
  tc_class pkgbuild-optdepends-deep-in-array-boring boring 0 \
    "$_deep_opt_old_pkg" \
    "$_deep_opt_new_pkg" \
    "$_deep_opt_old_src" \
    "$_deep_opt_new_src"

  tc_class optdepends-pkgbuild-srcinfo boring 0 \
    "$_old_opt_pkg" \
    "$_new_opt_pkg" \
    "$_old_opt_src" \
    "$_new_opt_src"

  tc_class optdepends-shell-expansion-review review 2 \
    "$_old_opt_pkg" \
    "$_new_opt_expansion_pkg" \
    "$_old_opt_src" \
    "$_new_opt_src"

  tc_class optdepends-plus-prepare review 2 \
    "$_old_opt_pkg" \
    "$_new_opt_sed_pkg" \
    "$_old_opt_src" \
    "$_new_opt_src"

  tc_class source-host-drift review 2 \
    "$_old_basic" \
    "$_evil_pkg" \
    "$_old_src" \
    "$_evil_src"

  tc_class multiline-source boring_edge 2 \
    "$_old_basic" \
    "$_edge_pkgbuild" \
    "$_old_src" \
    "$_host_src"
  local _edge_dir="$_CLASS_DIR" _edge_base="$_CLASS_BASE" _edge_tip="$_CLASS_TIP" _edge_pkg="cls-multiline-source"

  tc_class build-logic review 2 \
    "$_old_basic" \
    "$_old_basic"$'\nbuild() {\n  make\n}' \
    "$_old_src" "$_old_src"

  tc_class hard-pattern hard 1 \
    "$_old_basic" \
    "$_old_basic"$'\nbuild() { npm install payload; }' \
    "$_old_src" "$_old_src"

  classify_diff_rules bad-ref "$_edge_dir" "0000000000000000000000000000000000000000" >/dev/null 2>&1
  local _bad_class="$SCAN_DIFF_CLASS" _bad_rc
  _LLM_TEST_CALLS=0
  scan_diff_rules bad-ref "$_edge_dir" "0000000000000000000000000000000000000000" >/dev/null 2>&1
  _bad_rc=$?
  if [ "$_bad_class" = audit_unavailable ] && [ "$_bad_rc" -eq 2 ] && [ "$_LLM_TEST_CALLS" -eq 0 ]; then
    log "  $(c_green "PASS") classifier-audit-unavailable-no-llm"; pass=$((pass+1))
  else
    log "  $(c_red "FAIL") classifier-audit-unavailable-no-llm"
    fail=$((fail+1))
  fi

  # shellcheck disable=SC2329  # test seam, called indirectly by llm_check_boring_edge
  _llm_boring_backend() {
    local n=0
    if [[ -r "$_LLM_TEST_COUNT_FILE" ]]; then
      read -r n <"$_LLM_TEST_COUNT_FILE"
    fi
    printf '%s\n' "$((n + 1))" >"$_LLM_TEST_COUNT_FILE"
    case "$_LLM_TEST_MODE" in
      ok) printf 'VERDICT: BORING_EDGE_OK\nREASON: test seam\n' ;;
      needs) printf 'VERDICT: NEEDS_HUMAN\n' ;;
      malformed) printf 'BORING\n' ;;
      fail) return 1 ;;
      missing) return 127 ;;
    esac
  }

  tl() { # tl name enabled mode expect-rc expect-calls
    local name="$1" enabled="$2" mode="$3" expect_rc="$4" expect_calls="$5" got_rc got_calls
    LLM_AUTO_BORING="$enabled"; _LLM_TEST_MODE="$mode"; _LLM_TEST_COUNT_FILE="$_cls_state/llm-count"
    printf '0\n' >"$_LLM_TEST_COUNT_FILE"
    scan_diff_rules "$_edge_pkg" "$_edge_dir" "$_edge_base" >/dev/null 2>&1
    got_rc=$?
    read -r got_calls <"$_LLM_TEST_COUNT_FILE"
    if [ "$got_rc" -eq "$expect_rc" ] && [ "$got_calls" -eq "$expect_calls" ]; then
      log "  $(c_green "PASS") llm-$name"; pass=$((pass+1))
    else
      log "  $(c_red "FAIL") llm-$name (expected rc $expect_rc/calls $expect_calls, got rc $got_rc/calls $got_calls)"
      fail=$((fail+1))
    fi
  }
  tl disabled-not-invoked 0 ok 2 0
  tl exact-ok-auto-passes 1 ok 0 1
  tl needs-human-reviews 1 needs 2 1
  tl malformed-reviews 1 malformed 2 1
  tl command-failure-reviews 1 fail 2 1
  tl missing-pi-reviews 1 missing 2 1

  printf '%s\t%s\t%s\n' "$_edge_base" "1970-01-01T00:00:00Z" "file://$_edge_dir" >"$ACCEPTED_DIR/$_edge_pkg"
  _AUR_TEST_DIR="$_edge_dir"; AUR_SAFE_STAGING=1
  LLM_AUTO_BORING=1; _LLM_TEST_MODE=ok; _LLM_TEST_CALLS=0
  ta "llm-auto-green-check-stages-tip" 0 check_pkg "$_edge_pkg"
  if [ -f "$STAGED_DIR/$_edge_pkg" ] && [ "$(awk -F '\t' '{print $1}' "$STAGED_DIR/$_edge_pkg")" = "$_edge_tip" ]; then
    log "  $(c_green "PASS") llm-auto-green-staged-sha"; pass=$((pass+1))
  else log "  $(c_red "FAIL") llm-auto-green-staged-sha"; fail=$((fail+1)); fi
  AUR_SAFE_STAGING=""; _AUR_TEST_DIR=""

  unset -f _class_bld tc_class tl _llm_boring_backend
  LLM_AUTO_BORING="$_cls_old_llm"
  STATE_DIR="$_cls_sd"; ACCEPTED_DIR="$_cls_ad"; STAGED_DIR="$_cls_st"; MANIFEST_FILE="$_cls_mf"
  rm -rf "$_clx" "$_cls_state"

  _AUR_TEST_Q=""
  unset -f _bl_bld

  AUR_SAFE_STAGING=""
  AUR_URL="$_osr"; STATE_DIR="$_osd2"; STAGED_DIR="$_ost2"; MANIFEST_FILE="$_omf2"
  rm -rf "$_fbx" "$_fsd"

  log ""
  log "  $(c_bold "$pass passed, $fail failed")"
  exit $fail
}

usage() {
  cat <<EOF
aur-safe — deterministic gate for AUR updates

usage:
  aur-safe gate                gate all pending AUR updates
  aur-safe check <pkg> ...     gate specific cached package(s)
  aur-safe audit <pkg>         advisory scan of an uncached/new package
  aur-safe scan                scan installed pkgs for payload patterns
  aur-safe explain [pkg]       LLM second-opinion on last flagged diff
  aur-safe accept              promote staged refs (called by the wrapper)
  aur-safe rules               list active rules
  aur-safe wrapper             print the suggested shell wrapper (not installed)
  aur-safe selftest            run built-in rule tests

env:
  AUR_SAFE_YAY_CACHE          yay cache dir     (default: ~/.cache/yay)
  AUR_SAFE_PARU_CACHE         paru cache dir    (default: ~/.cache/paru/clone)
  AUR_SAFE_STATE_DIR          state dir         (default: ~/.cache/aur-safe)
  AUR_SAFE_MODEL              explain model     (default: zai/glm-5.2)
  AUR_SAFE_EXPLAIN_MAXLINES   diff truncation   (default: 1000)
  AUR_SAFE_BRANCH             remote branch     (default: master)
  AUR_SAFE_AUR_URL            AUR base URL      (default: https://aur.archlinux.org)
  AUR_SAFE_CONFIG             config file       (default: ~/.config/aur-safe/config)
  AUR_SAFE_LLM_AUTO_BORING    1 enables strict LLM verifier for boring-edge diffs
EOF
}

###############################################################################
# dispatch
###############################################################################
[[ $# -eq 0 ]] && { usage; exit 3; }
case "$1" in
  gate)     shift; cmd_gate "$@" ;;
  check)    shift; cmd_check "$@" ;;
  audit)    shift; cmd_audit "$@" ;;
  scan)     shift; cmd_scan "$@" ;;
  explain)  shift; cmd_explain "$@" ;;
  accept)   shift; cmd_accept "$@" ;;
  rules)    shift; cmd_rules "$@" ;;
  wrapper)  shift; cmd_wrapper "$@" ;;
  selftest) shift; cmd_selftest "$@" ;;
  -h|--help|help) usage ;;
  *) die "unknown command '$1' (try: aur-safe --help)" ;;
esac
