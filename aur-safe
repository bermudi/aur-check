  printf -v _new_dup_dep_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\ndepends=(\n  'old-aur-dep'\n  'alsa-lib'\n)\n  'alsa-lib'\nsource=(\"https://example.com/pkg-1.tar\")\nsha256sums=(%s)" "$_sum1"
  printf -v _new_inline_stray_dep_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\ndepends=()\n  'alsa-lib'\nsource=(\"https://example.com/pkg-1.tar\")\nsha256sums=(%s)" "$_sum1"
  _old_dep_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tdepends = old-aur-dep\n\tsource = https://example.com/pkg-1.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _new_repo_dep_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tdepends = alsa-lib\n\tsource = https://example.com/pkg-1.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _new_aur_dep_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tdepends = suspicious-aur-dep\n\tsource = https://example.com/pkg-1.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _new_dup_dep_src="$_old_dep_src"$'\n\tdepends = alsa-lib'
  _old_space_src=$'pkgbase = cls-pkg\n        pkgver = 1.0\n        pkgrel = 1\n        provides = cls-virtual\n        conflicts = cls-old\n        options = !strip\n        backup = etc/cls.conf\n\npkgname = cls-pkg'
  _new_tab_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tprovides = cls-virtual\n\tconflicts = cls-old\n\toptions = !strip\n\tbackup = etc/cls.conf\n\npkgname = cls-pkg'
  # Test fixtures for validpgpkeys hex bypass (finding E): baseline has a
  # validpgpkeys array; update adds one 40-char hex fingerprint. Before the
  # fix, the bare-hex fast-path in _boring_added_line_class would classify
  # this as boring (0), silently auto-clearing a trust-anchor change.
  printf -v _old_vpgp_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsource=("https://example.com/pkg-1.tar")\nsha256sums=(%s)\nvalidpgpkeys=("' "$_sum1"
  _old_vpgp_pkg+="  0123456789ABCDEF0123456789ABCDEF01234567"
  _old_vpgp_pkg+=$'\n)\n'
  printf -v _new_vpgp_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsource=("https://example.com/pkg-1.tar")\nsha256sums=(%s)\nvalidpgpkeys=("' "$_sum1"
  _new_vpgp_pkg+="  0123456789ABCDEF0123456789ABCDEF01234567"
  _new_vpgp_pkg+=$'\n  \'"FEDCBA9876543210FEDCBA9876543210FEDCBA98'"\n)\n"
  printf -v _comment_vpgp_old_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsha256sums=(\n  '%s'\n) # checksums\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n)" "$_sum1"
  printf -v _comment_vpgp_new_pkg "pkgname=cls-pkg\npkgver=1.1\npkgrel=1\nsha256sums=(\n  '%s'\n) # checksums\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n  'FEDCBA9876543210FEDCBA9876543210FEDCBA98'\n)" "$_sum1"
  printf -v _inline_vpgp_old_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsha256sums=(\n  '%s')\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n)" "$_sum1"
  printf -v _inline_vpgp_new_pkg "pkgname=cls-pkg\npkgver=1.1\npkgrel=1\nsha256sums=(\n  '%s')\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n  'FEDCBA9876543210FEDCBA9876543210FEDCBA98'\n)" "$_sum1"
  printf -v _quoted_hash_old_pkg "pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsha256sums=(\n  '%s # literal') # checksums\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n)" "$_sum1"
  printf -v _quoted_hash_new_pkg "pkgname=cls-pkg\npkgver=1.1\npkgrel=1\nsha256sums=(\n  '%s # literal') # checksums\nvalidpgpkeys=(\n  '0123456789ABCDEF0123456789ABCDEF01234567'\n  'FEDCBA9876543210FEDCBA9876543210FEDCBA98'\n)" "$_sum1"
  _quoted_gadget_old_pkg=$'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\n_dummy=\'\nsha256sums=(\n\'\nvalidpgpkeys=(\n  \'0123456789ABCDEF0123456789ABCDEF01234567\'\n)'
  _quoted_gadget_new_pkg=$'pkgname=cls-pkg\npkgver=1.1\npkgrel=1\n_dummy=\'\nsha256sums=(\n\'\nvalidpgpkeys=(\n  \'0123456789ABCDEF0123456789ABCDEF01234567\'\n  \'FEDCBA9876543210FEDCBA9876543210FEDCBA98\'\n)'
  _old_vpgp_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/pkg-1.tar\n\tsha256sums = '"$_sum1"$'\n\tvalidpgpkeys = 0123456789ABCDEF0123456789ABCDEF01234567\n\npkgname = cls-pkg'
  _new_vpgp_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/pkg-1.tar\n\tsha256sums = '"$_sum1"$'\n\tvalidpgpkeys = 0123456789ABCDEF0123456789ABCDEF01234567\n\tvalidpgpkeys = FEDCBA9876543210FEDCBA9876543210FEDCBA98\n\npkgname = cls-pkg'
  # Test fixture for .SRCINFO section-move (finding CR-major): depends=foo
  # moves from pkgbase section to pkgname section with the SAME indent.
  _old_src_move_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tdepends = foo\n\npkgname = cls-pkg'
  _new_src_move_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\npkgname = cls-pkg\n\tdepends = foo'
  # Test fixtures for intra-pkgbase deps: a split pkgbase (cls-split) with two
  # members, cls-split and cls-split-tools. The version-pinned depends= below
  # reference the pkgbase itself or a sibling member — they are NOT in the test
  # pacman sync db, so the only thing that can clear them is the intra-pkgbase
  # branch of _srcinfo_repo_dep_added_line. This is the nvidia-580xx-utils
  # shape (opencl-nvidia-580xx depends on sibling nvidia-580xx-utils). PKGBUILD
  # is a multi-pkgname split build; only pkgver changes across the diff.
  printf -v _split_old_pkgbuild 'pkgbase=cls-split\npkgver=1.0\npkgrel=1\nsource=("https://example.com/split.tar")\nsha256sums=(%s)\npkgname=(cls-split cls-split-tools)' "$_sum1"
  printf -v _split_new_pkgbuild 'pkgbase=cls-split\npkgver=2.0\npkgrel=1\nsource=("https://example.com/split.tar")\nsha256sums=(%s)\npkgname=(cls-split cls-split-tools)' "$_sum1"
  # Dep on the pkgbase itself (also a member): cls-split-tools depends on
  # cls-split, version-pinned to pkgver. pkgver bump 1.0 -> 2.0.
  _split_base_old_src=$'pkgbase = cls-split\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/split.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-split\n\npkgname = cls-split-tools\n\tdepends = cls-split=1.0'
  _split_base_new_src=$'pkgbase = cls-split\n\tpkgver = 2.0\n\tpkgrel = 1\n\tsource = https://example.com/split.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-split\n\npkgname = cls-split-tools\n\tdepends = cls-split=2.0'
  # Dep on a sibling member (not the pkgbase): cls-split depends on
  # cls-split-tools, version-pinned to pkgver.
  _split_member_old_src=$'pkgbase = cls-split\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/split.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-split\n\tdepends = cls-split-tools=1.0\n\npkgname = cls-split-tools'
  _split_member_new_src=$'pkgbase = cls-split\n\tpkgver = 2.0\n\tpkgrel = 1\n\tsource = https://example.com/split.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-split\n\tdepends = cls-split-tools=2.0\n\npkgname = cls-split-tools'

  tc_class version-bump boring 0 "$_old_basic" "$_new_basic" "$_old_src" "$_new_src"

  tc_class checksum-only boring 0 \
    "$_old_basic" \
    "$_sum2_pkg" \
    "$_old_src" \
    "$_sum2_src"

  tc_class multiline-checksum-only boring 0 \
    "$_old_multi_sum_pkg" \
    "$_new_multi_sum_pkg" \
    "$_old_src" \
    "$_sum2_src"

  tc_class same-host-source boring 0 \
    "$_old_basic" \
    "$_host_pkg" \
    "$_old_src" \
    "$_host_src"

  tc_class optdepends-srcinfo boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\toptdepends = ntfsprogs: NTFS partition support'

  tc_class srcinfo-advisory-metadata boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tpkgdesc = Fast, secure browser\n\turl = https://example.com/project\n\tarch = x86_64\n\tlicense = custom:opera\n\tgroups = browsers'

  tc_class srcinfo-repo-deps boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tdepends = alsa-lib\n\tdepends = ttf-font\n\tmakedepends = cmake\n\tcheckdepends = alsa-lib>=1.2'

  tc_class srcinfo-unknown-dep-review review 2 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tdepends = suspicious-aur-dep'

  # PKGBUILD dependencies mirror .SRCINFO semantically, but are shell syntax:
  # only literal single-quoted entries inside dependency arrays may inherit the
  # installed/sync-db/intra-pkgbase trust decision. Expansion, unknown AUR
  # dependencies, and a quoted token outside the array must remain reviewable.
  tc_class pkgbuild-repo-dep boring 0 \
    "$_old_dep_pkg" "$_new_repo_dep_pkg" "$_old_dep_src" "$_new_repo_dep_src"
  tc_class pkgbuild-unknown-dep-review review 2 \
    "$_old_dep_pkg" "$_new_aur_dep_pkg" "$_old_dep_src" "$_new_aur_dep_src"
  tc_class pkgbuild-expansion-dep-review review 2 \
    "$_old_dep_pkg" "$_new_expansion_dep_pkg" "$_old_dep_src" "$_new_repo_dep_src"
  tc_class pkgbuild-stray-literal-review review 2 \
    "$_old_stray_dep_pkg" "$_new_stray_dep_pkg" "$_old_dep_src" "$_new_repo_dep_src"
  tc_class pkgbuild-safe-duplicate-cannot-mask-stray review 2 \
    "$_old_dup_dep_pkg" "$_new_dup_dep_pkg" "$_old_dep_src" "$_new_dup_dep_src"
  _class_bld "$_clx" cls-removed-opener-latch \
    "$_old_dup_dep_pkg" "$_new_inline_stray_dep_pkg" "$_old_dep_src" "$_new_repo_dep_src"
  if _pkgbuild_repo_dep_added_line "$_CLASS_DIR" "$_CLASS_BASE" "  'alsa-lib'"; then
    log "  $(c_red "FAIL") classifier-removed-opener-cannot-latch"; fail=$((fail+1))
  else
    log "  $(c_green "PASS") classifier-removed-opener-cannot-latch"; pass=$((pass+1))
  fi

  # PKGBUILD build-var assigned a bare git SHA (_commit=<hex>, optionally
  # quoted). Inert: the RHS of a string assignment is never executed; it just
  # selects which same-host path source=() fetches, verified by the *sums=()
  # array. The cursor-bin shape. Three variants: unquoted, single, double.
  printf -v _commit_old_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\n_commit=%s\nsource=("https://example.com/${_commit}/pkg.tar")\nsha256sums=(%s)' \
    "4aa8ff1b7877ed7bd01bcba308698f71a6735380" "$_sum1"
  printf -v _commit_new_pkg_unq 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\n_commit=%s\nsource=("https://example.com/${_commit}/pkg.tar")\nsha256sums=(%s)' \
    "042b3c1a4c53f2c3808067f519fbfc67b72cad8b" "$_sum1"
  printf -v _commit_new_pkg_sq "pkgname=cls-pkg\npkgver=2.0\npkgrel=1\n_commit='%s'\nsource=(\"https://example.com/\${_commit}/pkg.tar\")\nsha256sums=(%s)" \
    "042b3c1a4c53f2c3808067f519fbfc67b72cad8b" "$_sum1"
  printf -v _commit_new_pkg_dq 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\n_commit="%s"\nsource=("https://example.com/${_commit}/pkg.tar")\nsha256sums=(%s)' \
    "042b3c1a4c53f2c3808067f519fbfc67b72cad8b" "$_sum1"
  _commit_old_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tsource = https://example.com/4aa8ff1b7877ed7bd01bcba308698f71a6735380/pkg.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _commit_new_src=$'pkgbase = cls-pkg\n\tpkgver = 2.0\n\tpkgrel = 1\n\tsource = https://example.com/042b3c1a4c53f2c3808067f519fbfc67b72cad8b/pkg.tar\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  tc_class pkgbuild-commit-var-unquoted boring 0 \
    "$_commit_old_pkg" "$_commit_new_pkg_unq" "$_commit_old_src" "$_commit_new_src"
  tc_class pkgbuild-commit-var-single-quoted boring 0 \
    "$_commit_old_pkg" "$_commit_new_pkg_sq" "$_commit_old_src" "$_commit_new_src"
  tc_class pkgbuild-commit-var-double-quoted boring 0 \
    "$_commit_old_pkg" "$_commit_new_pkg_dq" "$_commit_old_src" "$_commit_new_src"

  # PKGBUILD build-var assigned a dotted-decimal version (the opera-developer
  # shape: _nwjs_ffmpeg_version=0.113.0). Inert for the same reason _commit=<hex>
  # is: the RHS of a string assignment never executes, and the version only
  # selects a path in source=() whose artifact is verified by *sums=(). The
  # var-name is NOT restricted here (unlike _commit): a dotted decimal cannot be
  # a PGP fingerprint (hex) or checksum (hex/SKIP), so the RHS format is the
  # security boundary. Two variants: plain decimal (0.113.0) and 'v'-prefixed
  # (v25.3.0). The motivating package var is _nwjs_ffmpeg_version, not _version
  # — a name allowlist would miss it.
  printf -v _ver_old_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\n_nwjs_ffmpeg_version=0.112.0\nsource=("https://example.com/${_nwjs_ffmpeg_version}/ffmpeg.zip")\nsha256sums=(%s)' "$_sum1"
  printf -v _ver_new_pkg_dec 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\n_nwjs_ffmpeg_version=0.113.0\nsource=("https://example.com/${_nwjs_ffmpeg_version}/ffmpeg.zip")\nsha256sums=(%s)' "$_sum1"
  printf -v _ver_new_pkg_vpref 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\n_electron_version=v25.3.0\nsource=("https://example.com/${_electron_version}/electron.zip")\nsha256sums=(%s)' "$_sum1"
  tc_class pkgbuild-version-var-decimal boring 0 \
    "$_ver_old_pkg" "$_ver_new_pkg_dec" "$_commit_old_src" "$_commit_new_src"
  tc_class pkgbuild-version-var-vprefixed boring 0 \
    "$_ver_old_pkg" "$_ver_new_pkg_vpref" "$_commit_old_src" "$_commit_new_src"

  # Regression: a version-looking build-var RHS that is command substitution
  # must NOT clear — the $ breaks the dotted-decimal match (same rejection path
  # as the _commit command-subst regression below). Payload-free substitution
  # isolates the classifier question; a real payload hits hard rules first.
  printf -v _ver_subst_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\n_version=$(echo 1.2.3)\nsource=("https://example.com/pkg.tar")\nsha256sums=(%s)' "$_sum1"
  tc_class pkgbuild-version-var-command-subst-review review 2 \
    "$_ver_old_pkg" "$_ver_subst_pkg" "$_commit_old_src" "$_commit_new_src"

  # Regression: a build-var RHS that is command substitution (not a bare hex
  # SHA) must NOT clear via the _commit rule — it executes at source time. Use a
  # payload-free substitution so the hard-rule pipeline doesn't fire first; this
  # isolates the classifier question (regex must reject `$`/non-hex RHS). Note:
  # a real malicious payload (curl|sh etc.) is caught earlier by the hard rules
  # as rc=1 hard-block, which is even stronger — this test exercises the
  # classifier's own rejection path.
  printf -v _commit_subst_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\n_commit=$(date)\nsource=("https://example.com/pkg.tar")\nsha256sums=(%s)' "$_sum1"
  tc_class pkgbuild-commit-var-command-subst-review review 2 \
    "$_commit_old_pkg" "$_commit_subst_pkg" "$_commit_old_src" "$_commit_new_src"

  # Regression (delegate-review Finding 1): a NON-conventional _var assigned a
  # lowercase 40-hex value must NOT clear via the _commit rule — even though
  # such a value is a valid PGP fingerprint. This closes the validpgpkeys-
  # indirection gap: with an unchanged validpgpkeys=($_evil) already present, a
  # newly-added _evil=<lowercase-40hex> would change the trust anchor, so it
  # must reach review. The rule's var-name allowlist (_commit/_gittag/_gitrev/
  # _tag/_rev) is what closes the gap — _evil is not in it. (Lowercase is NOT
  # a defense; validpgpkeys= accepts any case. The var-name restriction is.)
  _commit_evil_pkg=$'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nvalidpgpkeys=($_evil)\n_evil=0123456789abcdef0123456789abcdef01234567\nsource=("https://example.com/pkg.tar")\nsha256sums='"($_sum1)"
  tc_class pkgbuild-commit-var-arbitrary-name-review review 2 \
    "$_commit_old_pkg" "$_commit_evil_pkg" "$_commit_old_src" "$_commit_new_src"

  # Symmetric positive control for the version-var rule: mirrors the _evil hex
  # regression above, but with validpgpkeys=($_evil) UNCHANGED across baseline
  # and new, so the sole diff line is _evil=<value>. (The hex test above adds
  # validpgpkeys=() itself, so its review result is overdetermined — it can't
  # isolate the _evil line.) With a dotted-decimal RHS, _evil=1.2.3 cannot be a
  # PGP fingerprint (gpg rejects it loudly → build breaks, not silent anchor
  # advance) and cannot be a checksum, so clearing it is safe even with the
  # validpgpkeys indirection present: the RHS format is the boundary, not the
  # var name. This documents-by-test the contrast with the hex shape (review).
  printf -v _ver_evil_old_pkg 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nvalidpgpkeys=($_evil)\n_evil=0.0.0\nsource=("https://example.com/pkg.tar")\nsha256sums=(%s)' "$_sum1"
  _ver_evil_pkg=$'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nvalidpgpkeys=($_evil)\n_evil=1.2.3\nsource=("https://example.com/pkg.tar")\nsha256sums='"($_sum1)"
  tc_class pkgbuild-version-var-fingerprint-shape-boring boring 0 \
    "$_ver_evil_old_pkg" "$_ver_evil_pkg" "$_commit_old_src" "$_commit_new_src"

  # noextract= is .SRCINFO metadata (a versioned *filename*, runs no code) —
  # an added/changed line must not force review. Append to an otherwise
  # unchanged .SRCINFO so the only diff is the noextract line.
  tc_class srcinfo-noextract-boring boring 0 \
    "$_old_basic" \
    "$_old_basic" \
    "$_old_src" \
    "$_old_src"$'\n\tnoextract = foo-1.0.deb'

  # Real cursor-bin shape: version bump renames the noextract= filename AND the
  # source= URL (same host) AND the sha512sum. noextract + source + checksum
  # must all clear as boring.
  printf -v _noextract_old_pkgbuild 'pkgname=cls-pkg\npkgver=1.0\npkgrel=1\nsource=("https://example.com/foo-1.0.deb")\nsha256sums=(%s)' "$_sum1"
  printf -v _noextract_new_pkgbuild 'pkgname=cls-pkg\npkgver=2.0\npkgrel=1\nsource=("https://example.com/foo-2.0.deb")\nsha256sums=(%s)' "$_sum1"
  _noextract_old_src=$'pkgbase = cls-pkg\n\tpkgver = 1.0\n\tpkgrel = 1\n\tnoextract = foo-1.0.deb\n\tsource = https://example.com/foo-1.0.deb\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'
  _noextract_new_src=$'pkgbase = cls-pkg\n\tpkgver = 2.0\n\tpkgrel = 1\n\tnoextract = foo-2.0.deb\n\tsource = https://example.com/foo-2.0.deb\n\tsha256sums = '"$_sum1"$'\n\npkgname = cls-pkg'

  tc_class srcinfo-noextract-version-rename boring 0 \
    "$_noextract_old_pkgbuild" \
    "$_noextract_new_pkgbuild" \
    "$_noextract_old_src" \
    "$_noextract_new_src"

  # Arch-qualified .SRCINFO source_<arch> = lines (the opencode-bin /
  # visual-studio-code-bin shape): a version bump renames the per-arch source
  # URL on the SAME host. PKGBUILD carries matching source_<arch>=(...) arrays.
  # Before the fix, the .SRCINFO source_x86_64 = / source_aarch64 = lines fell
  # through _boring_added_line_class to review (no matcher for the space-
  # delimited arch-qualified source form), producing a false-positive review on
  # an otherwise-identical version bump. Now symmetric with the arch-qualified
  # sha*sums_<arch> = form that already cleared.
